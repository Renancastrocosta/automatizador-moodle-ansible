# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
#
# Servidor alvo: Ubuntu Server 22.04 LTS (versão oficial do projeto)

# ======================
# SERVIDOR / ANSIBLE
# ======================
MOODLE_HOST=192.168.1.100
ANSIBLE_USER=ubuntu
ANSIBLE_SSH_PRIVATE_KEY_FILE=~/.ssh/id_ed25519

# ======================
# MOODLE
# ======================
MOODLE_DOMAIN=moodle.seudominio.com
MOODLE_PORT=8080
# URL que o usuário digita no navegador (sem porta se usar proxy nginx na 80)
MOODLE_WWWROOT=http://moodle.seudominio.com
MOODLE_VERSION=MOODLE_405_STABLE
MOODLE_LANG=pt_br
MOODLE_SITE_FULLNAME="Minha Plataforma Moodle"
MOODLE_SITE_SHORTNAME=moodle

# Conta administrador criada na instalação
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=altere_senha_admin
MOODLE_ADMIN_EMAIL=admin@seudominio.com

# ======================
# DATABASE
# ======================
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=altere_esta_senha

# ======================
# PATHS (no servidor remoto)
# ======================
MOODLE_DATA_DIR=/data/moodle
POSTGRES_DATA_DIR=/data/postgres
BACKUP_DIR=/backup

# ======================
# SYSTEM
# ======================
POSTGRES_VERSION=17
TIMEZONE=America/Sao_Paulo

# ======================
# SSL (playbook ssl.yml)
# ======================
LETSENCRYPT_EMAIL=seuemail@dominio.com
